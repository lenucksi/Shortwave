{
    "id": "de.haeckerfelix.Shortwave",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable",
        "org.freedesktop.Sdk.Extension.llvm21"
    ],
    "command": "shortwave",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--socket=pulseaudio",
        "--talk-name=org.gtk.vfs.*",
        "--filesystem=xdg-run/gvfsd",
        "--filesystem=xdg-music"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm21/bin"
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig"
    ],
    "modules": [
        {
            "name": "libshumate",
            "buildsystem": "meson",
            "config-opts": [
                "--libdir=/app/lib",
                "-Dgir=false",
                "-Dvapi=false",
                "-Dgtk_doc=false",
                "-Ddemos=false",
                "-Dvector_renderer=false"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/libshumate.git",
                    "tag": "1.4.0",
                    "commit": "06021e35f0d479612fb1a3af91a73ba562175e03"
                }
            ]
        },
        {
            "name": "shortwave",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                },
                "generated-sources.json",
                {
                    "type": "shell",
                    "commands": [
                        "mkdir -p .cargo",
                        "cp ../build-aux/cargo-config .cargo/config"
                    ]
                }
            ]
        }
    ]
}
